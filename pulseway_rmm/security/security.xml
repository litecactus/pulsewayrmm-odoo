<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_pulseway_user" model="res.groups">
        <field name="name">Pulseway User</field>
        <field name="category_id" ref="base.module_category_services_helpdesk"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_pulseway_admin" model="res.groups">
        <field name="name">Pulseway Administrator</field>
        <field name="category_id" ref="base.module_category_services_helpdesk"/>
        <field name="implied_ids" eval="[(4, ref('pulseway_rmm.group_pulseway_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
